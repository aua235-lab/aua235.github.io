<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>차선태의 디지털 포트폴리오 - Cheongnam Diary</title>
    <style>
        :root {
            --primary-blue: #a3d8f4;
            --secondary-blue: #1e3a8a;
            --text-blue: #004080;
            --bg-white: #ffffff;
            --accent-yellow: #fdf6e3;
            --accent-green: #e9f5e1;
            --font-family: 'Malgun Gothic', 'Apple SD Gothic Neo', sans-serif;
        }

        body {
            margin: 0;
            font-family: var(--font-family);
            background-color: var(--primary-blue);
            color: var(--text-blue);
            background-image: url('data:image/svg+xml;base64,'); /* Leaf motif simulation */
            background-repeat: repeat;
        }

        .header {
            background-color: var(--accent-yellow);
            padding: 20px;
            text-align: center;
            border-bottom: 3px solid var(--primary-blue);
        }

        .header h1 {
            margin: 0;
            font-size: 2.5em;
            color: var(--text-blue);
            font-weight: bold;
        }

        .nav {
            background-color: var(--accent-yellow);
            padding: 10px 0;
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        .nav a {
            text-decoration: none;
            color: var(--text-blue);
            font-weight: bold;
            font-size: 1.1em;
            transition: color 0.3s;
        }

        .nav a:hover {
            color: #4CAF50;
        }

        .container {
            display: flex;
            gap: 30px;
            max-width: 1400px;
            margin: 30px auto;
            padding: 0 20px;
        }

        .sidebar {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .main-content {
            flex: 2.5;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .card {
            background-color: var(--bg-white);
            border-radius: 20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            padding: 25px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }

        .banner {
            height: 350px;
            background-image: linear-gradient(to right, rgba(163, 216, 244, 0.8), rgba(253, 246, 227, 0.6)), url('data:image/svg+xml;base64,'); /* Sun flare simulation */
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: var(--bg-white);
            margin-bottom: 30px;
        }

        .banner h2 {
            font-size: 3em;
            margin: 0 0 10px 0;
        }

        .banner p {
            font-size: 1.2em;
            max-width: 80%;
        }

        .profile-photo {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 5px solid var(--primary-blue);
            margin-right: 20px;
            object-fit: cover;
        }

        .profile-photo-lg {
            width: 150px;
            height: 150px;
        }

        .search-container {
            display: flex;
            align-items: center;
            border: 2px solid var(--primary-blue);
            border-radius: 30px;
            padding: 10px 20px;
            margin-bottom: 20px;
            background-color: var(--accent-yellow);
        }

        .search-container input {
            border: none;
            background: none;
            outline: none;
            flex: 1;
            font-size: 1.1em;
            color: var(--text-blue);
        }

        .chat-title, .diary-title, .friends-title, .note-title {
            font-size: 1.6em;
            font-weight: bold;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .chat-line {
            display: flex;
            margin-bottom: 10px;
            font-size: 1em;
            line-height: 1.4;
        }

        .chat-author {
            font-weight: bold;
            margin-right: 10px;
            color: var(--secondary-blue);
        }

        .chat-line.sunter .chat-author {
            color: red; /* Highlight Suntae's lines in chat */
        }

        .friend-profile-card {
            background-color: var(--accent-green);
            padding: 15px;
            border-radius: 15px;
            flex: 1;
            text-align: center;
        }

        .friend-photo {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            margin-bottom: 10px;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
            background-color: var(--accent-yellow);
            padding: 10px;
            border-radius: 10px;
        }

        .calendar-day {
            background-color: var(--bg-white);
            padding: 10px;
            border-radius: 5px;
            text-align: center;
        }

        .calendar-day-header {
            font-weight: bold;
            color: var(--secondary-blue);
        }

        .calendar-day-highlight {
            background-color: var(--primary-blue);
            color: var(--bg-white);
        }

        .calendar-day-event {
            font-size: 0.8em;
            margin-top: 5px;
            color: var(--text-blue);
        }

        .thumbnail-photo {
            width: 100px;
            height: 100px;
            border-radius: 10px;
            border: 3px solid var(--accent-green);
            object-fit: cover;
        }

        .note-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .note-item {
            background-color: #fef3c7; /* Light beige for notes */
            border-radius: 10px;
            padding: 15px;
            font-family: 'Comic Sans MS', cursive; /* Simulated note handwriting */
            font-style: italic;
        }

        .footer {
            background-color: var(--text-blue);
            color: var(--bg-white);
            text-align: center;
            padding: 15px;
            margin-top: 30px;
        }
    </style>
</head>
<body>

