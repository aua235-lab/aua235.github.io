<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>차선태의 디지털 포트폴리오 - Cheongnam Diary</title>
    <style>
        :root {
            --primary-blue: #a3d8f4;
            --secondary-blue: #1e3a8a;
            --text-blue: #004080;
            --bg-white: #ffffff;
            --accent-yellow: #fdf6e3;
            --accent-green: #e9f5e1;
            --font-family: 'Malgun Gothic', 'Apple SD Gothic Neo', sans-serif;
        }

        body {
            margin: 0;
            font-family: var(--font-family);
            background-color: var(--primary-blue);
            color: var(--text-blue);
            /* 배경 이미지 투명도 및 색상 블렌딩 처리 */
            background-image: linear-gradient(rgba(163, 216, 244, 0.85), rgba(163, 216, 244, 0.85)), url('KakaoTalk_20260704_102926361.png');
            background-size: cover;
            background-attachment: fixed;
            background-position: center;
        }

        .header {
            background-color: var(--accent-yellow);
            padding: 20px;
            text-align: center;
            border-bottom: 3px solid var(--primary-blue);
        }

        .header h1 {
            margin: 0;
            font-size: 2.5em;
            color: var(--text-blue);
            font-weight: bold;
        }

        .nav {
            background-color: var(--accent-yellow);
            padding: 10px 0;
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        .nav a {
            text-decoration: none;
            color: var(--text-blue);
            font-weight: bold;
            font-size: 1.1em;
            transition: color 0.3s;
        }

        .nav a:hover {
            color: #4CAF50;
        }

        .container {
            display: flex;
            gap: 30px;
            max-width: 1400px;
            margin: 30px auto;
            padding: 0 20px;
        }

        .sidebar {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .main-content {
            flex: 2.5;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .card {
            background-color: var(--bg-white);
            border-radius: 20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            padding: 25px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }

        .main-profile-img {
            width: 100%;
            border-radius: 15px;
            object-fit: cover;
            margin-bottom: 15px;
            box-shadow: 0 5px 10px rgba(0,0,0,0.05);
        }

        .banner {
            height: 250px;
            background-image: linear-gradient(to right, rgba(163, 216, 244, 0.8), rgba(253, 246, 227, 0.6)), url('KakaoTalk_20260704_102926361_01.png');
            background-size: cover;
            background-position: center;
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: var(--text-blue);
            text-shadow: 1px 1px 2px rgba(255,255,255,0.8);
        }

        .banner h2 {
            font-size: 2.8em;
            margin: 0 0 10px 0;
        }

        .banner p {
            font-size: 1.2em;
            max-width: 80%;
            font-weight: bold;
        }

        .search-container {
            display: flex;
            align-items: center;
            border: 2px solid var(--primary-blue);
            border-radius: 30px;
            padding: 10px 20px;
            margin-bottom: 20px;
            background-color: var(--accent-yellow);
        }

        .search-container input {
            border: none;
            background: none;
            outline: none;
            flex: 1;
            font-size: 1.1em;
            color: var(--text-blue);
        }

        .section-title {
            font-size: 1.6em;
            font-weight: bold;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .chat-line {
            display: flex;
            margin-bottom: 10px;
            font-size: 1em;
            line-height: 1.4;
        }

        .chat-author {
            font-weight: bold;
            margin-right: 10px;
            color: var(--secondary-blue);
        }

        .chat-line.sunter .chat-author {
            color: #ff4d4d;
        }

        .friends-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }

        .friend-profile-card {
            background-color: var(--accent-green);
            padding: 15px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .friend-profile-card.highlight {
            background-color: var(--accent-yellow);
            border: 2px solid var(--primary-blue);
        }

        .friend-photo {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            margin-bottom: 10px;
            object-fit: cover;
            border: 3px solid var(--bg-white);
        }

        .calendar-section {
            display: flex;
            gap: 20px;
        }

        .calendar-grid {
            flex: 2;
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
            background-color: var(--accent-yellow);
            padding: 10px;
            border-radius: 10px;
        }

        .calendar-day {
            background-color: var(--bg-white);
            padding: 10px;
            border-radius: 5px;
            text-align: center;
            font-size: 0.9em;
        }

        .calendar-day-header {
            font-weight: bold;
            color: var(--secondary-blue);
        }

        .calendar-day-highlight {
            background-color: var(--primary-blue);
            color: var(--text-blue);
            font-weight: bold;
        }

        .calendar-day-event {
            font-size: 0.75em;
            margin-top: 5px;
            color: #ff4d4d;
            display: block;
        }

        .school-info-side {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .school-img {
            width: 100%;
            border-radius: 10px;
            border: 3px solid var(--accent-green);
            object-fit: cover;
        }

        .note-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .note-item {
            background-color: #fef3c7;
            border-radius: 10px;
            padding: 15px;
            font-style: italic;
            line-height: 1.5;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.05);
        }

        .footer {
            background-color: var(--text-blue);
            color: var(--bg-white);
            text-align: center;
            padding: 15px;
            margin-top: 30px;
        }
    </style>
</head>
<body>

<div class="header">
    <h1>SUNTAE'S DIGITAL PORTFOLIO</h1>
</div>

<div class="nav">
    <a href="#">HOME</a>
    <a href="#cha-sun-tae">CHA SUN-TAE</a>
    <a href="#cheongnam-4">청람 4인방</a>
